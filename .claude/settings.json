{
  "permissions": {
    "allow": [
      "mcp__vibeshift__update_node",
      "mcp__vibeshift__search_nodes",
      "mcp__vibeshift__list_edges",
      "mcp__vibeshift__delete_edge",
      "mcp__vibeshift__link_nodes",
      "mcp__vibeshift__check_impact",
      "mcp__vibeshift__create_changelog",
      "mcp__vibeshift__list_projects",
      "mcp__vibeshift__create_node",
      "mcp__vibeshift__consult_context"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[HOOK] コード変更を検知。必ずVibeShiftのMCPサーバー経由でノードへの反映が必要か確認し、必要であればノードの追加・更新・削除をしてください。スキップ禁止。'"
          }
        ]
      }
    ]
  }
}
