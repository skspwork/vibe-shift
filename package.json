{
  "name": "vibeshift",
  "description": "AI-driven requirements traceability management system",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/skspwork/vibe-shift.git"
  },
  "private": true,
  "packageManager": "pnpm@9.5.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "db:generate": "pnpm --filter @vibeshift/api db:generate",
    "db:migrate": "pnpm --filter @vibeshift/api db:migrate"
  },
  "devDependencies": {
    "turbo": "^2.8.20"
  }
}
